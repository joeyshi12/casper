# Casper server configuration
# Bind address - 0.0.0.0 makes the server reachable on your LAN (so a phone on the
# same WiFi can hit it). Keep it behind CASPER_TOKEN.
HOST=0.0.0.0
PORT=4319

# Shared secret entered once on the login screen. The server exchanges it for an
# httpOnly session cookie (an opaque per-device token); the raw secret is never
# stored in the browser. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CASPER_TOKEN=change-me

# Device-login lifetime in seconds (slid forward on activity). Default: 7 days.
# Logins persist in ~/.casper/logins.json and survive restarts; revoke them per
# device (or everywhere) from the Devices screen. Changing CASPER_TOKEN only
# affects new logins - existing device sessions stay valid until they expire or
# are revoked (delete logins.json, log out everywhere, or run `casper reset-token`).
# CASPER_SESSION_TTL_SECONDS=604800

# Path to the kiro-cli binary. Defaults to resolving `kiro-cli` on PATH.
KIRO_BIN=kiro-cli

# Explicit Node binary used by the `casper` runner. The installer records the
# resolved absolute path here so the service starts even under a minimal PATH
# (e.g. a systemd user unit). Defaults to `node` on PATH.
# CASPER_NODE=node

# Default working directory for new sessions (where the agent operates).
DEFAULT_CWD=/workplace/joeyshi

# Filesystem root that file-serving endpoints (directory picker, inline image
# rendering) are confined to. Requests resolving outside this root are rejected.
# Defaults to the filesystem root (/), so browsing spans everything the server
# process can read. Set a narrower path (e.g. your home directory) to prevent
# authenticated users from reading arbitrary system files.
# CASPER_FILE_ROOT=/home/youruser

# Max number of LIVE kiro-cli acp child processes kept in memory at once.
# Idle sessions beyond this are evicted (LRU) and become DORMANT (resumable).
MAX_LIVE_SESSIONS=6

# Default agent (ACP "mode") for new sessions. The installer links the bundled
# `casper` agent (assets/agents/casper.json) into ~/.kiro/agents and sets this
# to `casper`; falls back to `kiro_default` if that agent is unavailable or invalid.
DEFAULT_AGENT=casper
